<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="RestimMaui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:RestimMaui.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Control" Icon="play_circle.png">
            <ShellContent ContentTemplate="{DataTemplate local:ControlPage}" />
        </Tab>
        <Tab Title="Device" Icon="sliders.png">
            <ShellContent ContentTemplate="{DataTemplate local:DeviceSettingsPage}" />
        </Tab>
        <Tab Title="Pulse" Icon="bolt.png">
            <ShellContent ContentTemplate="{DataTemplate local:PulseSettingsPage}" />
        </Tab>
        <Tab Title="Media" Icon="play.png">
            <ShellContent ContentTemplate="{DataTemplate local:MediaSyncPage}" />
        </Tab>
        <Tab Title="Settings" Icon="cog.png">
            <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" />
        </Tab>
    </TabBar>

</Shell>
