# FOC Companion Environment Configuration Example
# Copy this file to .env and fill in your actual values.
# DO NOT commit the actual .env file to version control!

# Device Connectivity
# Default IP address of the FOC-Stim device
DEFAULT_DEVICE_IP=192.168.1.100

# WebDAV Synchronization (Optional)
# URL of your WebDAV server for funscript synchronization
# WEBDAV_URL=https://your-server.com/webdav
# WEBDAV_USERNAME=your_username
# WEBDAV_PASSWORD=your_password

# Beta Distribution (Internal Use Only)
# FIREBASE_APP_ID=
# APPCENTER_TOKEN=
