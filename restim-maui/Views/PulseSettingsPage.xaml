<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RestimMaui.ViewModels"
             x:Class="RestimMaui.Views.PulseSettingsPage"
             Title="Pulse">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Pulse Configuration" FontSize="18" FontAttributes="Bold" />

            <Label Text="Carrier Frequency (Hz)" />
            <Slider Minimum="{Binding MinCarrier}" Maximum="{Binding MaxCarrier}" Value="{Binding CarrierFreq}" />
            <Label Text="{Binding CarrierFreq, StringFormat='{0:F0} Hz'}" HorizontalOptions="End"/>

            <Label Text="Pulse Frequency (Hz)" />
            <Slider Minimum="1" Maximum="100" Value="{Binding PulseFreq}" />
            <Label Text="{Binding PulseFreq, StringFormat='{0:F0} Hz'}" HorizontalOptions="End"/>

            <Label Text="Pulse Width (cycles)" />
            <Slider Minimum="3" Maximum="15" Value="{Binding PulseWidth}" />
            <Label Text="{Binding PulseWidth, StringFormat='{0:F0}'}" HorizontalOptions="End"/>

            <Label Text="Pulse Rise Time (cycles)" />
            <Slider Minimum="2" Maximum="5" Value="{Binding PulseRise}" />
            <Label Text="{Binding PulseRise, StringFormat='{0:F0}'}" HorizontalOptions="End"/>

            <Label Text="Randomization (%)" />
            <Slider Minimum="0" Maximum="100" Value="{Binding PulseRandom}" />
            <Label Text="{Binding PulseRandom, StringFormat='{0:F0}%'}" HorizontalOptions="End"/>

            <Button Text="Save Pulse Settings" Command="{Binding SaveCommand}" BackgroundColor="#27ae60" Margin="0,20,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
