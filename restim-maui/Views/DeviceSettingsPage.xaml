<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RestimMaui.ViewModels"
             x:Class="RestimMaui.Views.DeviceSettingsPage"
             Title="Device">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Safety Limits" FontSize="18" FontAttributes="Bold" />
            
            <Label Text="Min Carrier Frequency (Hz)" />
            <Slider Minimum="100" Maximum="2000" Value="{Binding MinFrequency}" />
            <Label Text="{Binding MinFrequency, StringFormat='{0:F0} Hz'}" HorizontalOptions="End"/>

            <Label Text="Max Carrier Frequency (Hz)" />
            <Slider Minimum="100" Maximum="2000" Value="{Binding MaxFrequency}" />
            <Label Text="{Binding MaxFrequency, StringFormat='{0:F0} Hz'}" HorizontalOptions="End"/>

            <Label Text="Max Amplitude (mA)" />
            <Slider Minimum="10" Maximum="150" Value="{Binding Amplitude}" />
            <Label Text="{Binding Amplitude, StringFormat='{0:F0} mA'}" HorizontalOptions="End"/>

            <BoxView HeightRequest="1" Color="Gray" />
            <Label Text="Calibration" FontSize="18" FontAttributes="Bold" />

            <Label Text="Center" />
            <Slider Minimum="-2" Maximum="2" Value="{Binding CalCenter}" />
            <Label Text="{Binding CalCenter, StringFormat='{0:F2}'}" HorizontalOptions="End"/>

            <Label Text="Up" />
            <Slider Minimum="-2" Maximum="2" Value="{Binding CalUp}" />
            <Label Text="{Binding CalUp, StringFormat='{0:F2}'}" HorizontalOptions="End"/>

            <Label Text="Left" />
            <Slider Minimum="-2" Maximum="2" Value="{Binding CalLeft}" />
            <Label Text="{Binding CalLeft, StringFormat='{0:F2}'}" HorizontalOptions="End"/>

            <Button Text="Save Settings" Command="{Binding SaveCommand}" BackgroundColor="#27ae60" Margin="0,20,0,0"/>
            <Button Text="Reset Defaults" Command="{Binding ResetCommand}" BackgroundColor="#95a5a6" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
